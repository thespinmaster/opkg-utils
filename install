#!/usr/bin/env bash
set -euo pipefail

# Bash equivalent of the Makefile install target.
# Defaults match the Makefile and can be overridden via environment variables:
#   DESTDIR=/tmp/stage PREFIX=/usr ./makefile-install.sh install

UTILS=(
  opkg-build
  opkg-unbuild
  opkg-compare-versions
  opkg-make-index
  opkg.py
  opkg-list-fields
  arfile.py
  opkg-buildpackage
  opkg-diff
  opkg-extract-file
  opkg-show-deps
  opkg-compare-indexes
  opkg-compare-versions.sh
)

DESTDIR="${DESTDIR:-}"
PREFIX="${PREFIX:-/usr/local}"
BINDIR="${PREFIX}/bin"

usage() {
  cat <<'EOF'
Usage:
  ./makefile-install.sh install

Environment overrides:
  DESTDIR   Installation staging root (default: empty)
  PREFIX    Installation prefix (default: /usr/local)
  CC        C compiler (default: cc)
  CFLAGS    Compiler flags (default: empty)
EOF
}

if [[ "${1:-}" != "install" ]]; then
  usage
  exit 1
fi

CC_BIN="${CC:-cc}"
CFLAGS_STR="${CFLAGS:-}"

# Match Makefile dependency: build opkg-compare-versions first.
${CC_BIN} ${CFLAGS_STR} -o opkg-compare-versions opkg-compare-versions.c

install -d "${DESTDIR}${BINDIR}"
install -m 755 "${UTILS[@]}" "${DESTDIR}${BINDIR}"

echo "Installed to ${DESTDIR}${BINDIR}"
